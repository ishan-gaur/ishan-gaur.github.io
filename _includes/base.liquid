<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/base.css"/>
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [["$", "$"], ["\\(", "\\)"]],
                displayMath: [["$$", "$$"], ["\\[", "\\]"]],
            },
        };
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
</head>
<body>
    <nav class="site-nav">
        <a href="/" class="{% if page.url == '/' %}active{% endif %}">Home</a>
        <a href="/bookshelf/" class="{% if page.url contains '/bookshelf/' %}active{% endif %}">Bookshelf</a>
        <a href="/writing/" class="{% if page.url contains '/writing/' %}active{% endif %}">Writing</a>
        <a href="/proteinguide/" class="{% if page.url contains '/using-proteinguide' or page.url == '/proteinguide/' %}active{% endif %}">ProteinGuide</a>
        <a href="https://ishan-gaur.github.io/proteingen/">ProteinGen</a>
    </nav>
    <main>
        <article>{{ content }}</article>
    </main>
</body>
